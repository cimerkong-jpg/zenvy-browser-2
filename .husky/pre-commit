#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# 1. Build check
echo "📦 Building project..."
npm run build || {
  echo "❌ Build failed! Fix errors before committing."
  exit 1
}

# 2. Type check
echo "🔍 Type checking..."
npm run typecheck || {
  echo "❌ Type check failed! Fix TypeScript errors."
  exit 1
}

# 3. Run tests if exist
if [ -f "test-antidetect.js" ]; then
  echo "🧪 Running tests..."
  node test-antidetect.js || {
    echo "⚠️  Tests failed! Review before committing."
    # Don't exit - allow commit with warning
  }
fi

echo "✅ Pre-commit checks passed!"
