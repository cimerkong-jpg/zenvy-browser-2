{
  "manifest_version": 3,
  "name": "WebRTC Blocker",
  "version": "1.0.0",
  "description": "Block WebRTC to prevent IP leaks",
  "permissions": ["webRequest"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
